{
  "compilerOptions": {
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["index.tsx", "src/**/*.ts", "src/**/*.tsx", "vite.config.mts"],
  "exclude": ["node_modules", "node_modules.*", "desktop-app", "release"]
}
