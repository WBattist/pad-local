{
  "name": "pad-local-desktop",
  "version": "2.0.0",
  "private": true,
  "description": "A self-contained local whiteboard and development workspace",
  "main": "electron/main.cjs",
  "author": "WBattist",
  "dependencies": {
    "@atyrode/excalidraw": "^0.18.0-15",
    "@monaco-editor/react": "^4.7.0",
    "lucide-react": "^0.488.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^9.2.1",
    "electron": "^37.2.6",
    "electron-builder": "^26.0.12",
    "typescript": "^5",
    "vite": "5.2.0",
    "wait-on": "^8.0.4"
  },
  "scripts": {
    "start": "node scripts/prepare-assets.cjs && vite",
    "dev": "node scripts/prepare-assets.cjs && concurrently -k \"vite\" \"wait-on http://127.0.0.1:3003 && electron .\"",
    "desktop": "electron .",
    "build": "node scripts/prepare-assets.cjs && vite build && npm run prepare:desktop",
    "prepare:desktop": "node scripts/prepare-desktop.cjs",
    "typecheck": "tsc --noEmit",
    "dist:win": "npm run build && electron-builder --win nsis",
    "pack:win": "npm run build && electron-builder --win dir",
    "dist:linux": "npm run build && electron-builder --linux AppImage tar.gz",
    "pack:linux": "npm run build && electron-builder --linux dir"
  },
  "build": {
    "appId": "com.wbattist.padlocal",
    "productName": "Pad Local",
    "asar": true,
    "npmRebuild": false,
    "directories": {
      "app": "desktop-app",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.png",
      "artifactName": "Pad-Local-Setup-${version}-${arch}.${ext}",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "artifactName": "Pad-Local-linux.${ext}",
      "category": "Development",
      "executableName": "pad-local",
      "target": [
        "AppImage",
        "tar.gz"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
