{
  "name": "pad-local-desktop",
  "version": "2.0.0",
  "private": true,
  "description": "A self-contained local whiteboard and development workspace",
  "main": "electron/main.cjs",
  "author": "WBattist",
  "dependencies": {
    "@atyrode/excalidraw": "^0.18.0-15",
    "@monaco-editor/react": "^4.7.0",
    "@tanstack/react-query": "^5.74.3",
    "@tanstack/react-query-devtools": "^5.74.3",
    "@types/crypto-js": "^4.2.2",
    "browser-fs-access": "0.29.1",
    "clsx": "^2.1.1",
    "crypto-js": "^4.2.0",
    "lodash.isequal": "^4.5.0",
    "lodash.throttle": "^4.1.1",
    "lucide-react": "^0.488.0",
    "posthog-js": "^1.236.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-use-websocket": "^4.13.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "zod": "^3.24.4"
  },
  "resolutions": {
    "cytoscape": "3.31.2",
    "**/cytoscape": "3.31.2"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^9.2.1",
    "electron": "^37.2.6",
    "electron-builder": "^26.0.12",
    "typescript": "^5",
    "vite": "5.2.0",
    "wait-on": "^8.0.4"
  },
  "scripts": {
    "start": "vite",
    "dev": "concurrently -k \"vite\" \"wait-on http://127.0.0.1:3003 && electron .\"",
    "desktop": "electron .",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "dist:win": "npm run build && electron-builder --win nsis portable",
    "pack:win": "npm run build && electron-builder --win dir"
  },
  "build": {
    "appId": "com.wbattist.padlocal",
    "productName": "Pad Local",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "artifactName": "Pad-Local-${version}-${arch}.${ext}",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
