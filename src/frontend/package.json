{
  "name": "pad-local-desktop",
  "version": "2.2.2",
  "private": true,
  "description": "A self-contained local whiteboard and development workspace",
  "main": "electron/main.cjs",
  "author": "WBattist",
  "dependencies": {
    "@atyrode/excalidraw": "^0.18.0-15",
    "@codingame/monaco-vscode-accessibility-service-override": "36.0.0",
    "@codingame/monaco-vscode-api": "^36.0.0",
    "@codingame/monaco-vscode-base-service-override": "36.0.0",
    "@codingame/monaco-vscode-configuration-service-override": "^36.0.0",
    "@codingame/monaco-vscode-css-default-extension": "36.0.0",
    "@codingame/monaco-vscode-dialogs-service-override": "36.0.0",
    "@codingame/monaco-vscode-environment-service-override": "36.0.0",
    "@codingame/monaco-vscode-explorer-service-override": "36.0.0",
    "@codingame/monaco-vscode-extension-gallery-service-override": "^36.0.0",
    "@codingame/monaco-vscode-extensions-service-override": "^36.0.0",
    "@codingame/monaco-vscode-files-service-override": "^36.0.0",
    "@codingame/monaco-vscode-html-default-extension": "36.0.0",
    "@codingame/monaco-vscode-javascript-default-extension": "36.0.0",
    "@codingame/monaco-vscode-json-default-extension": "36.0.0",
    "@codingame/monaco-vscode-keybindings-service-override": "^36.0.0",
    "@codingame/monaco-vscode-languages-service-override": "36.0.0",
    "@codingame/monaco-vscode-lifecycle-service-override": "36.0.0",
    "@codingame/monaco-vscode-log-service-override": "36.0.0",
    "@codingame/monaco-vscode-markdown-basics-default-extension": "36.0.0",
    "@codingame/monaco-vscode-markers-service-override": "36.0.0",
    "@codingame/monaco-vscode-model-service-override": "36.0.0",
    "@codingame/monaco-vscode-notifications-service-override": "36.0.0",
    "@codingame/monaco-vscode-output-service-override": "36.0.0",
    "@codingame/monaco-vscode-preferences-service-override": "36.0.0",
    "@codingame/monaco-vscode-python-default-extension": "36.0.0",
    "@codingame/monaco-vscode-quickaccess-service-override": "^36.0.0",
    "@codingame/monaco-vscode-search-service-override": "36.0.0",
    "@codingame/monaco-vscode-shellscript-default-extension": "36.0.0",
    "@codingame/monaco-vscode-storage-service-override": "36.0.0",
    "@codingame/monaco-vscode-textmate-service-override": "36.0.0",
    "@codingame/monaco-vscode-theme-defaults-default-extension": "36.0.0",
    "@codingame/monaco-vscode-theme-service-override": "^36.0.0",
    "@codingame/monaco-vscode-treesitter-service-override": "36.0.0",
    "@codingame/monaco-vscode-typescript-basics-default-extension": "36.0.0",
    "@codingame/monaco-vscode-views-service-override": "36.0.0",
    "@codingame/monaco-vscode-walkthrough-service-override": "36.0.0",
    "@codingame/monaco-vscode-welcome-service-override": "36.0.0",
    "@codingame/monaco-vscode-workbench-service-override": "36.0.0",
    "@codingame/monaco-vscode-working-copy-service-override": "36.0.0",
    "@monaco-editor/react": "^4.7.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "lucide-react": "^0.488.0",
    "monaco-editor": "npm:@codingame/monaco-vscode-editor-api@^36.0.0",
    "node-pty": "^1.1.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "vscode": "npm:@codingame/monaco-vscode-extension-api@^36.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^9.2.1",
    "electron": "^37.2.6",
    "electron-builder": "^26.0.12",
    "typescript": "^5",
    "vite": "5.2.0",
    "wait-on": "^8.0.4"
  },
  "scripts": {
    "start": "node scripts/prepare-assets.cjs && vite",
    "dev": "node scripts/prepare-assets.cjs && concurrently -k \"vite\" \"wait-on http://localhost:3003 && electron .\"",
    "desktop": "electron .",
    "build": "node scripts/prepare-assets.cjs && vite build && npm run prepare:desktop",
    "prepare:desktop": "node scripts/prepare-desktop.cjs",
    "typecheck": "tsc --noEmit",
    "dist:win": "npm run build && electron-builder --win nsis",
    "pack:win": "npm run build && electron-builder --win dir",
    "dist:linux": "npm run build && electron-builder --linux AppImage tar.gz",
    "pack:linux": "npm run build && electron-builder --linux dir"
  },
  "build": {
    "appId": "com.wbattist.padlocal",
    "productName": "Pad Local",
    "asar": true,
    "npmRebuild": false,
    "asarUnpack": [
      "node_modules/node-pty/**/*"
    ],
    "directories": {
      "app": "desktop-app",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.png",
      "artifactName": "Pad-Local-Setup-${version}-${arch}.${ext}",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "artifactName": "Pad-Local-linux.${ext}",
      "category": "Development",
      "executableName": "pad-local",
      "target": [
        "AppImage",
        "tar.gz"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "node-pty"
    ]
  }
}
