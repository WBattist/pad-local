# Non-secret Pad Local defaults. Later values in runtime.env override these.
COMPOSE_PROJECT_NAME=pad-local
APP_PORT=8000
CODER_PORT=7080
KEYCLOAK_PORT=8080
POSTGRES_USER=padlocal
POSTGRES_DB=pad
CODER_POSTGRES_DB=coder
KEYCLOAK_POSTGRES_DB=keycloak
REDIS_HOST=redis
REDIS_PORT=6379
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
OIDC_REALM=pad-local
OIDC_CLIENT_ID=pad-local
KEYCLOAK_ADMIN=pad-admin
PAD_BOOTSTRAP_USER=pad
PAD_BOOTSTRAP_EMAIL=pad@localhost
CODER_TEMPLATE_NAME=pad-local
CODER_WORKSPACE_NAME=ubuntu
API_WORKERS=1
PAD_COOKIE_SECURE=false
CODER_ADDITIONAL_CSP_POLICY=frame-ancestors http://localhost:8000
CODER_IMAGE=ghcr.io/coder/coder:v2.31.8
KEYCLOAK_IMAGE=quay.io/keycloak/keycloak:26.2.5
