{
  "realm": "__OIDC_REALM__",
  "enabled": true,
  "displayName": "Pad Local",
  "registrationAllowed": false,
  "resetPasswordAllowed": true,
  "rememberMe": true,
  "loginWithEmailAllowed": true,
  "roles": {
    "realm": [
      { "name": "admin", "description": "Pad Local administrators" },
      { "name": "user", "description": "Pad Local users" }
    ]
  },
  "clients": [
    {
      "clientId": "__OIDC_CLIENT_ID__",
      "name": "Pad Local",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "__OIDC_CLIENT_SECRET__",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "publicClient": false,
      "frontchannelLogout": true,
      "rootUrl": "http://localhost:__APP_PORT__",
      "baseUrl": "http://localhost:__APP_PORT__",
      "adminUrl": "http://localhost:__APP_PORT__",
      "redirectUris": [
        "http://localhost:*/*",
        "http://127.0.0.1:*/*",
        "http://localhost:__APP_PORT__/api/auth/callback",
        "http://127.0.0.1:__APP_PORT__/api/auth/callback",
        "http://localhost:__CODER_PORT__/api/v2/users/oidc/callback",
        "http://127.0.0.1:__CODER_PORT__/api/v2/users/oidc/callback"
      ],
      "webOrigins": [
        "http://localhost:*",
        "http://127.0.0.1:*",
        "http://localhost:__APP_PORT__",
        "http://127.0.0.1:__APP_PORT__",
        "http://localhost:__CODER_PORT__",
        "http://127.0.0.1:__CODER_PORT__"
      ],
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:__APP_PORT__/*##http://localhost:__CODER_PORT__/*"
      },
      "protocolMappers": [
        {
          "name": "Pad audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "__OIDC_CLIENT_ID__",
            "id.token.claim": "true",
            "access.token.claim": "true"
          }
        },
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "user.attribute": "foo",
            "claim.name": "realm_access.roles",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "true"
          }
        }
      ],
      "defaultClientScopes": ["web-origins", "acr", "roles", "profile", "email"]
    }
  ],
  "users": [
    {
      "username": "__PAD_BOOTSTRAP_USER__",
      "email": "__PAD_BOOTSTRAP_EMAIL__",
      "firstName": "Pad",
      "lastName": "User",
      "enabled": true,
      "emailVerified": true,
      "realmRoles": ["admin", "user"],
      "credentials": [
        { "type": "password", "value": "__PAD_BOOTSTRAP_PASSWORD__", "temporary": false }
      ]
    }
  ]
}
